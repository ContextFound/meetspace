# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/meetspace

# Environment: development | production
ENVIRONMENT=development

# API key prefix: ms_live_ (production) or ms_test_ (development)
API_KEY_PREFIX=ms_test_

# CORS origins (JSON array). Overrides the defaults in config.py.
# CORS_ORIGINS=["https://yourdomain.com","https://www.yourdomain.com"]

# Admin panel — Firebase Auth
# On GCP (Cloud Run) credentials are automatic.
# For local dev, point to your service-account JSON:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/meetspace-events-service-account.json

# Allowed admin emails (JSON array). Empty = all authenticated users allowed.
# ADMIN_EMAILS=["you@example.com"]
